# Cloud Run 試験デプロイ用の環境変数
# 使い方:
#   GCP_PROJECT_ID=xxx AUTH_PASSWORD=xxx JWT_SECRET=xxx bash scripts/gcp/deploy-cloudrun-trial.sh

# GCPプロジェクトID（必須）
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Runリージョン（省略可、デフォルト: asia-northeast1）
# REGION=asia-northeast1

# アクセスパスワード（必須）
AUTH_PASSWORD=your-auth-password

# JWT署名シークレット（必須）
JWT_SECRET=your-jwt-secret-here

# 注: APP_ENV=local は deploy-cloudrun-trial.sh により自動設定されます。
# Firestoreおよびサービスアカウントは試験デプロイでは不要です。
