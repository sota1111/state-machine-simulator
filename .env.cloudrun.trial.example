# Cloud Run 試験デプロイ用の環境変数
# 使い方:
#   GCP_PROJECT_ID=xxx AUTH_SECRET=xxx FIREBASE_API_KEY=xxx bash scripts/gcp/deploy-cloudrun-trial.sh

# GCPプロジェクトID（必須）
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Runリージョン（省略可、デフォルト: asia-northeast1）
# REGION=asia-northeast1

# セッションcookie署名用シークレット（必須）
AUTH_SECRET=your-cookie-signing-secret

# Firebase Web API key（必須・サーバ側REST認証で使用）
FIREBASE_API_KEY=your-firebase-web-api-key

# 許可するメールアドレス（カンマ区切り、省略可。空の場合は全ユーザー許可）
# ALLOWED_USER_EMAILS=your-email@example.com

# 注: APP_ENV=local は deploy-cloudrun-trial.sh により自動設定されます。
# Firestoreおよびサービスアカウントは試験デプロイでは不要です。
