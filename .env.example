# ローカル開発用の環境変数
# Cloud Run本番環境では環境変数またはSecret Managerを使用してください

# アプリケーション環境 (local / production)
APP_ENV=local

# Anthropic API キー（自然言語解析機能に必要）
# 未設定でもサンプルデータの表示・シミュレーションは動作します
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# データベース設定（ローカル開発用）
DATABASE_URL=sqlite:////app/data/app.db

# GCP設定（APP_ENV=productionの場合に必要）
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1

# Firestore設定（APP_ENV=productionの場合に必要）
FIRESTORE_DATABASE=(default)

# CORS設定（カンマ区切り、APP_ENV=localのみ有効）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# フロントエンド設定
VITE_API_URL=http://localhost:8000

# ログレベル (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
