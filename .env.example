# ===================================
# State Machine Simulator 環境変数
# ===================================

# アプリ環境（local / production）
APP_ENV=local

# ===================================
# Claude API設定（AI解析機能使用時）
# ===================================

# Anthropic API キー（省略可。未設定時はAI解析機能を無効化して手動モードで利用可能）
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ===================================
# GCP / Firestore設定（production環境のみ）
# ===================================

# GCPプロジェクトID（APP_ENV=production のときのみ必要）
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# CORS設定（省略可、デフォルト: http://localhost:5173,http://localhost:3000）
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===================================
# 認証設定
# ===================================

# アクセスパスワード（必須）
AUTH_PASSWORD=your-password-here

# JWT署名シークレット（必須。長いランダム文字列を設定）
JWT_SECRET=your-jwt-secret-here
