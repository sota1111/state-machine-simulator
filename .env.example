# ===================================
# State Machine Simulator 環境変数
# ===================================

# アプリ環境（local / production）
APP_ENV=local

# ===================================
# Gemini API設定（AI解析機能使用時）
# ===================================

# Google Gemini API キー（省略可。未設定時はAI解析機能を無効化して手動モードで利用可能）
# GEMINI_API_KEY=your-gemini-api-key

# 使用するGeminiモデル（省略可、デフォルト: gemini-2.0-flash）
# GEMINI_MODEL=gemini-2.0-flash

# ===================================
# GCP / Firestore設定（production環境のみ）
# ===================================

# GCPプロジェクトID（APP_ENV=production のときのみ必要）
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# CORS設定（省略可、デフォルト: http://localhost:5173,http://localhost:3000）
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===================================
# Firebase Authentication設定（案1: サーバサイドREST認証）
# ===================================
# Firebase Web API key。ブラウザではなくサーバ側で Identity Toolkit REST
# (accounts:signInWithPassword) のメール/パスワード照合に使用する。
# 本番では Secret Manager で管理する（Cloud Run には FIREBASE_WEB_API_KEY として注入される）。
# Firebase Console > プロジェクト設定 > アプリ から取得
# FIREBASE_WEB_API_KEY が優先され、未設定時は FIREBASE_API_KEY にフォールバックする（どちらか一方でログイン可）。
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_API_KEY=your-firebase-web-api-key

# 許可するメールアドレス（カンマ区切り、空の場合は全ユーザー許可）
ALLOWED_USER_EMAILS=your-email@example.com

# セッションcookie署名用シークレット（32文字以上推奨）
AUTH_SECRET=your-random-secret-key-here

# Firestore用（GCP_PROJECT_IDと同じ値、production環境のみ）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ===================================
# GCP / Cloud Run デプロイ設定（deploy_local_gcp.sh 使用時）
# ===================================

# GCPプロジェクトID（必須）
GCP_PROJECT_ID=your-gcp-project-id

# リージョン（デフォルト: asia-northeast1）
GCP_REGION=asia-northeast1

# Cloud Run サービス名（デフォルト: state-machine-simulator）
CLOUD_RUN_SERVICE_NAME=state-machine-simulator

# Artifact Registry リポジトリ名（デフォルト: state-machine-registry）
ARTIFACT_REGISTRY_REPOSITORY=state-machine-registry

# Docker イメージ名（デフォルト: state-machine-app）
IMAGE_NAME=state-machine-app
